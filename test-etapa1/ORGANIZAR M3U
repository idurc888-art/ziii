Camada 2 — Matcher Engine(Web Worker)
Offline
4 estratégias de match em cascata
Roda em Web Worker — nunca bloqueia a UI.
// catalogMatcher.ts — cascata de confiança
function matchChannel(ch: Channel, catalog: CanonicalTitle[]): MatchResult {
    const slug = slugify(ch.name)

    // 1. Exact slug match  → score 100
    let hit = catalog.find(c => c.slug === slug)
    if (hit) return { canonical: hit, score: 100, method: 'exact' }

    // 2. AltTitle match   → score 92
    hit = catalog.find(c => c.altTitles.some(a => slugify(a) === slug))
    if (hit) return { canonical: hit, score: 92, method: 'alt' }

    // 3. StartsWith match → score 80
    hit = catalog.find(c => slug.startsWith(c.slug) || c.slug.startsWith(slug))
    if (hit) return { canonical: hit, score: 80, method: 'prefix' }

    // 4. Keywords match   → score 65
    hit = catalog.find(c =>
        c.matchHints.every(hint => ch.name.toLowerCase().includes(hint))
    )
    if (hit) return { canonical: hit, score: 65, method: 'keyword' }

    // Sem match → enriquecer via TMDB (baixa prioridade)
    return { canonical: null, score: 0, method: 'none' }
}
