Fase 2 — Matcher em Web Worker(1 dia)
typescript// src/workers/catalogMatcherWorker.ts
import { CANONICAL_CATALOG } from '../data/catalog'

self.onmessage = ({ data }: MessageEvent<{ channels: Channel[] }>) => {
    const matched: MatchedChannel[] = []
    const unmatched: Channel[] = []

    for (const ch of data.channels) {
        const result = matchChannel(ch, CANONICAL_CATALOG)
        if (result.score >= 65) {
            matched.push({ ...ch, canonical: result.canonical, matchScore: result.score })
        } else {
            unmatched.push(ch)
        }
    }

    self.postMessage({ matched, unmatched })
}
Fase 3 — CatalogMatcher singleton(1 dia)
typescript// src/services/catalogMatcher.ts
class CatalogMatcherClass {
    private matchedByStreaming = new Map<Streaming, { movies: MatchedChannel[]; series: MatchedChannel[] }>()

    async processChannels(channels: Channel[]): Promise<void> {
        // Roda no Worker — não bloqueia UI
        const worker = new Worker('./catalogMatcherWorker.ts', { type: 'module' })
        worker.postMessage({ channels })
        worker.onmessage = ({ data }) => {
            this.indexByStreaming(data.matched)
            // Enriquecer unmatched via TMDB em baixa prioridade
            setTimeout(() => this.enrichUnmatched(data.unmatched), 5000)
        }
    }

    getMatchedByStreaming() {
        return Object.fromEntries(this.matchedByStreaming)
    }
}

export const CatalogMatcher = new CatalogMatcherClass()
