Atualização do catálogo
Automático
Catálogo atualizado semanalmente via CDN fetch
App sempre tem os top filmes / séries do momento, sem rebuild.
// catalogService.ts — auto-update semanal
const CATALOG_URL = 'https://seu-cdn.com/ziiitv-catalog-v1.json'
const CATALOG_TTL = 7 * 24 * 60 * 60 * 1000  // 7 dias

async function loadCatalog(): Promise {
    // 1. IndexedDB cache (instantâneo)
    const cached = await db.get('catalog')
    if (cached && Date.now() - cached.fetchedAt < CATALOG_TTL) {
        return cached.data  // ← retorna em <5ms
    }
    // 2. Fetch novo (background, não bloqueia)
    const fresh = await fetch(CATALOG_URL).then(r => r.json())
    await db.put('catalog', { data: fresh, fetchedAt: Date.now() })
    return fresh
}
